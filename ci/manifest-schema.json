{
  "$id": "http://lcg/sd2.0/manifest.json",
  "type": "object",
  "properties": {
    "deploy": {
      "$id": "/properties/deploy",
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$id": "/properties/deploy/items",
        "type": "object",
        "properties": {
          "type": {
            "$id": "/properties/deploy/items/properties/type",
            "type": "string",
            "title": "Deployment Type",
            "description": "Specifies type of deployment to perform",
            "default": "",
            "examples": [
              "lrs"
            ]
          },
          "name": {
            "$id": "/properties/deploy/items/properties/name",
            "type": "string",
            "title": "The Name Schema ",
            "description": "Name given to the deployed service",
            "default": "",
            "examples": [
              "data-fabric-customer-login"
            ]
          },
          "container": {
            "$id": "/properties/deploy/items/properties/container",
            "type": "string",
            "title": "The Container Schema ",
            "description": "Docker Container for deployed service",
            "default": "",
            "examples": [
              "CONTAINER"
            ]
          },
          "port": {
            "$id": "/properties/deploy/items/properties/port",
            "type": "integer",
            "title": "The Port Schema ",
            "description": "Port inside container where service will listen",
            "default": 0,
            "examples": [
              8080
            ]
          },
          "healthcheck": {
            "$id": "/properties/deploy/items/properties/healthcheck",
            "type": "string",
            "title": "The Healthcheck Schema ",
            "default": "",
            "examples": [
              "HTTP:/ping"
            ]
          },
          "provides": {
            "$id": "/properties/deploy/items/properties/provides",
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "$id": "/properties/deploy/items/properties/provides/items",
              "type": "string",
              "title": "The 0th Schema ",
              "description": "Used for Service discovery",
              "default": "",
              "examples": [
                "customer",
                "login"
              ]
            }
          }
        },
        "required": [
          "type",
          "name",
          "provides"
        ]
      }
    },
    "require": {
      "$id": "/properties/require",
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$id": "/properties/require/items",
        "type": "object",
        "properties": {
          "type": {
            "$id": "/properties/require/items/properties/type",
            "type": "string",
            "title": "Required Type Schema ",
            "description": "Required services for deployment",
            "default": "",
            "examples": [
              "postgres"
            ]
          }
        }
      }
    }
  },
  "required": [
    "deploy",
    "require"
  ]
}
