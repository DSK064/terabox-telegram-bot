<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">
	<servers>
    <server>
      <username>${env.ARTIFACTORY_USR}</username>
      <password>${env.ARTIFACTORY_PSW}</password>
      <id>central</id>
    </server>
    <server>
      <username>${env.ARTIFACTORY_USR}</username>
      <password>${env.ARTIFACTORY_PSW}</password>
      <id>snapshots</id>
    </server>
	</servers>
    <!--<mirrors>
        <mirror>
            <mirrorOf>*</mirrorOf>
            <name>remote-repos</name>
            <url>https://artifactory.bwinparty.corp/artifactory/remote-repos</url>
            <id>remote-repos</id>
        </mirror>
        </mirrors>-->
    <profiles>
        <profile>
            <repositories>
                <repository>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <id>central</id>
                    <name>lcgomnia-maven-public</name>
                    <url>https://artifactory.bwinparty.corp/artifactory/lcgomnia-maven-public</url>
                </repository>
                <repository>
                    <snapshots />
                    <id>snapshots</id>
                    <name>lcgomnia-maven-snapshots</name>
                    <url>https://artifactory.bwinparty.corp/artifactory/lcgomnia-maven-public</url>
                </repository>
                <!--<repository>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <id>central</id>
                    <name>lcgomnia-maven-public</name>
                    <url>https://artifactory.bwinparty.corp/artifactory/remote-repos</url>
                </repository>-->
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <id>central</id>
                    <name>lcgomnia-maven-public</name>
                    <url>https://artifactory.bwinparty.corp/artifactory/lcgomnia-maven-public</url>
                </pluginRepository>
                <pluginRepository>
                    <snapshots />
                    <id>snapshots</id>
                    <name>lcgomnia-maven-snapshots</name>
                    <url>https://artifactory.bwinparty.corp/artifactory/lcgomnia-maven-public</url>
                </pluginRepository>
            </pluginRepositories>
            <id>artifactory</id>
        </profile>
    </profiles>
    <proxies>
        <proxy>
            <id>artifactory-proxy</id>
            <active>true</active>
            <protocol>http</protocol>
            <host>infrastructure-proxy</host>
            <port>3128</port>
            <nonProxyHosts>artifactory.bwinparty.corp</nonProxyHosts>
        </proxy>
    </proxies>
    <activeProfiles>
        <activeProfile>artifactory</activeProfile>
    </activeProfiles>
    <pluginGroups>
        <pluginGroup>com.fortify.sca.plugins.maven</pluginGroup>
    </pluginGroups>
</settings>